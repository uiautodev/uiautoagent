# OpenAI兼容模型配置
BASE_URL=https://.../v1
API_KEY=sk-xxx

# 默认模型
MODEL_NAME=doubao-seed-2.0-pro

# 可选：为不同场景配置不同的模型
# MODEL_PLAN=gpt-4o-mini          # AI计划模型（需要视觉能力）
# MODEL_DETECT=glm-5v-turbo       # 元素检测模型（需要视觉能力）
# MODEL_TEXT=gpt-4o-mini          # 文本处理模型（总结、澄清等）

# 请求超时时间（秒）
REQUEST_TIMEOUT=60

# OpenRouter 追踪（可选）
#OPENROUTER_SITE_URL=https://yoursite.com
#OPENROUTER_SITE_NAME=YourAppName
#SESSION_ID=my-session-123   # 默认自动生成 UUID
