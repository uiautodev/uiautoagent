# UIAutoAgent 环境变量配置
# 优先使用 UIAUTO_ 前缀的环境变量（向后兼容旧的无前缀变量名）

# ========== 基础配置 ==========
# OpenAI 兼容 API 配置
UIAUTO_BASE_URL=https://.../v1          # 或使用 BASE_URL（旧版兼容）
UIAUTO_API_KEY=sk-xxx                    # 或使用 API_KEY（旧版兼容）

# ========== 模型配置 ==========
# 默认模型（所有场景的通用默认值）
UIAUTO_MODEL_NAME=doubao-seed-2.0-pro   # 或使用 MODEL_NAME（旧版兼容）

# 可选：为不同场景配置不同的模型
# UIAUTO_MODEL_PLAN=gpt-4o-mini          # AI计划模型（需要视觉能力）
# UIAUTO_MODEL_DETECT=glm-5v-turbo       # 元素检测模型（需要视觉能力）
# UIAUTO_MODEL_TEXT=gpt-4o-mini          # 文本处理模型（总结、澄清等）

# 旧版环境变量名（仍然支持，但推荐使用 UIAUTO_ 前缀）
# MODEL_PLAN=gpt-4o-mini
# MODEL_DETECT=glm-5v-turbo
# MODEL_TEXT=gpt-4o-mini

# ========== 网络配置 ==========
# 请求超时时间（秒）
UIAUTO_REQUEST_TIMEOUT=60                # 或使用 REQUEST_TIMEOUT（旧版兼容）

# 代理配置（可选）
# UIAUTO_MODEL_PROXY=http://127.0.0.1:7890  # 或使用 MODEL_PROXY（旧版兼容）

# ========== OpenRouter 追踪（可选）==========
# OPENROUTER_SITE_URL=https://yoursite.com
# OPENROUTER_SITE_NAME=YourAppName
# SESSION_ID=my-session-123   # 默认自动生成 UUID
